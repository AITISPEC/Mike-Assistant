  <!-- ============================================= -->
  <!-- Автоматическое копирование и раскладывание файлов -->
  <!-- ============================================= -->
  <!-- Копирование нативных DLL Sherpa (onnxruntime.dll, sherpa-onnx-c-api.dll) в папку Sherpa -->
  <Target Name="CopySherpaNativeLibraries" AfterTargets="Build">
    <MakeDir Directories="$(OutputPath)Sherpa" />
    <ItemGroup>
      <!-- Путь к нативным DLL внутри пакета (версия 1.12.34, но можно использовать wildcard) -->
      <_SherpaNativeFiles Include="$(ProjectDir)packages\org.k2fsa.sherpa.onnx.runtime.win-x64.*\runtimes\win-x64\native\*.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_SherpaNativeFiles)" DestinationFolder="$(OutputPath)Sherpa" SkipUnchangedFiles="true" />
  </Target>
  <!-- Копирование управляемой обёртки sherpa-onnx.dll также в папку Sherpa (рядом с нативными) -->
  <Target Name="CopySherpaManaged" AfterTargets="CopySherpaNativeLibraries">
    <ItemGroup>
      <_SherpaManaged Include="$(OutputPath)sherpa-onnx.dll" />
    </ItemGroup>
    <Copy SourceFiles="@(_SherpaManaged)" DestinationFolder="$(OutputPath)Sherpa" SkipUnchangedFiles="true" />
    <Delete Files="@(_SherpaManaged)" />
  </Target>
  <!-- Раскладывание остальных DLL и XML по папкам NAudio, System, Microsoft, Config -->
  <Target Name="OrganizeOutputFiles" AfterTargets="CopyFilesToOutputDirectory">
    <!-- Создаём папки -->
    <MakeDir Directories="$(OutputPath)NAudio" />
    <MakeDir Directories="$(OutputPath)System" />
    <MakeDir Directories="$(OutputPath)Microsoft" />
    <MakeDir Directories="$(OutputPath)Config" />
    <!-- NAudio (включая основные NAudio.dll, NAudio.xml) -->
    <ItemGroup>
      <_NAudioFiles Include="$(OutputPath)NAudio.dll;$(OutputPath)NAudio.xml" />
      <_NAudioFiles Include="$(OutputPath)NAudio.*.dll;$(OutputPath)NAudio.*.xml" />
    </ItemGroup>
    <Copy SourceFiles="@(_NAudioFiles)" DestinationFolder="$(OutputPath)NAudio" SkipUnchangedFiles="true" />
    <!-- System -->
    <ItemGroup>
      <_SystemFiles Include="$(OutputPath)System.*.dll;$(OutputPath)System.*.xml" />
    </ItemGroup>
    <Copy SourceFiles="@(_SystemFiles)" DestinationFolder="$(OutputPath)System" SkipUnchangedFiles="true" />
    <!-- Microsoft -->
    <ItemGroup>
      <_MicrosoftFiles Include="$(OutputPath)Microsoft.*.dll;$(OutputPath)Microsoft.*.xml" />
    </ItemGroup>
    <Copy SourceFiles="@(_MicrosoftFiles)" DestinationFolder="$(OutputPath)Microsoft" SkipUnchangedFiles="true" />
    <!-- Остальные файлы (исключаем уже обработанные и особые) -->
    <ItemGroup>
      <_OtherFiles Include="$(OutputPath)*.dll" Exclude="$(OutputPath)MikeAssistant.exe;&#xD;&#xA;                          $(OutputPath)NAudio.dll;&#xD;&#xA;                          $(OutputPath)NAudio.*.dll;&#xD;&#xA;                          $(OutputPath)System.*.dll;&#xD;&#xA;                          $(OutputPath)Microsoft.*.dll;&#xD;&#xA;                          $(OutputPath)sherpa-onnx.dll;&#xD;&#xA;                          $(OutputPath)Sherpa\**;&#xD;&#xA;                          $(OutputPath)Grammars\**" />
      <_OtherFiles Include="$(OutputPath)*.xml" Exclude="$(OutputPath)MikeAssistant.exe.config;&#xD;&#xA;                          $(OutputPath)NAudio.xml;&#xD;&#xA;                          $(OutputPath)NAudio.*.xml;&#xD;&#xA;                          $(OutputPath)System.*.xml;&#xD;&#xA;                          $(OutputPath)Microsoft.*.xml;&#xD;&#xA;                          $(OutputPath)Sherpa\**;&#xD;&#xA;                          $(OutputPath)Grammars\**" />
      <_OtherFiles Include="$(OutputPath)*.json" Exclude="$(OutputPath)Sherpa\**;$(OutputPath)Grammars\**" />
    </ItemGroup>
    <Copy SourceFiles="@(_OtherFiles)" DestinationFolder="$(OutputPath)Config" SkipUnchangedFiles="true" />
    <!-- Удаляем скопированные файлы из корня -->
    <Delete Files="@(_NAudioFiles)" />
    <Delete Files="@(_SystemFiles)" />
    <Delete Files="@(_MicrosoftFiles)" />
    <Delete Files="@(_OtherFiles)" />
  </Target>
  <!-- Дополнительно: удаляем лишние PDB из корня (опционально) -->
  <Target Name="CleanRootPdb" AfterTargets="OrganizeOutputFiles">
    <Delete Files="$(OutputPath)MikeAssistant.pdb" />
  </Target>
